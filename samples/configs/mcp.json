{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "github-mcp-server"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_TOKEN"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
    },
    "workshop-remote": {
      "serverUrl": "https://your-mcp-server.example.com/sse",
      "env": {
        "API_KEY": "$MCP_API_KEY"
      }
    }
  }
}
